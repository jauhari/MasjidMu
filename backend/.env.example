# ─── Runtime ─────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ─── Database (Neon) ─────────────────────────────────────────────
# https://console.neon.tech → Project → Connection Details
DATABASE_URL=postgresql://user:pass@ep-xxx.ap-southeast-1.aws.neon.tech/masjidmu?sslmode=require

# ─── Auth (better-auth) ──────────────────────────────────────────
# Generate: openssl rand -base64 32
BETTER_AUTH_SECRET=replace-with-random-32-byte-string-aaaa
BETTER_AUTH_URL=http://localhost:3000

# ─── Cache (Upstash Redis) ───────────────────────────────────────
# https://console.upstash.com
UPSTASH_REDIS_URL=https://xxx.upstash.io
UPSTASH_REDIS_TOKEN=AXXXXxxxx

# ─── Storage (Cloudflare R2) ─────────────────────────────────────
# https://dash.cloudflare.com → R2 → API tokens
R2_ACCOUNT_ID=
R2_ACCESS_KEY=
R2_SECRET_KEY=
R2_BUCKET=masjidmu-media

# ─── Email (Resend) ──────────────────────────────────────────────
# https://resend.com/api-keys
RESEND_API_KEY=re_

# ─── Monitoring (optional in dev) ────────────────────────────────
SENTRY_DSN=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
