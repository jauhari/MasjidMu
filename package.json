{
  "name": "masjidmu",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "dev": "pnpm --filter @masjidmu/backend dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "build:fe": "pnpm --filter @masjidmu/frontend build",
    "deploy:cf": "pnpm build:fe && pnpm --filter @masjidmu/frontend deploy:cf",
    "deploy:cf:preview": "pnpm build:fe && pnpm --filter @masjidmu/frontend deploy:cf:preview"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "@types/node": "^20.0.0"
  }
}
